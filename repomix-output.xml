import time
from typing import Dict, Any, Optional
from backend.app.core.logger import logger

class EpisodicMemory:
    def __init__(self, memory_orchestrator):
        self.memory = memory_orchestrator

    async def log_event(self, user_id: str, persona_id: str, event_type: str, data: Dict[str, Any]):
        """Сохраняет событие в специальную коллекцию episodic_{persona_id} или episodic_global."""
        collection_persona = f"episodic_{persona_id}" if persona_id else "episodic_global"
        timestamp = data.get("timestamp") or time.time()
        text = f"[{event_type}] {data.get('user_message', '')[:100]}"
        metadata = {
            "event_type": event_type,
            "timestamp": timestamp,
            "importance": data.get("importance"),
        }
        try:
            await self.memory.add_user_memory(
                user_id,
                text=text,
                persona_id=collection_persona,
                metadata=metadata
            )
            logger.debug(f"EpisodicMemory: событие '{event_type}' сохранено (важность {data.get('importance')})")
        except Exception as e:
            logger.error(f"EpisodicMemory: ошибка сохранения события: {e}")
    async def get_recent_events(self, user_id: str,
                                 persona_id: str,
                                   limit: int=50):
        collection_persona = f"episodic_{persona_id}" if persona_id else "episodic_global"
        try:
            events = await self.memory.get_all_memories(user_id,persona_id=collection_persona)
            logger.debug(f"EpisodicMemory: получено {len(events)} событий для {user_id}/{persona_id}")
            return events[-limit:]
        except Exception as e :
            logger.error(f"EpisodicMemory: ошибка получения событий: {e}")
            return []
