            cleaned = re.sub(r'^```(?:json)?\s*\n?', '', raw, flags=re.MULTILINE)
            cleaned = re.sub(r'\n?```\s*$', '', cleaned, flags=re.MULTILINE)
            parsed = schema.model_validate_json(cleaned)
            return parsed, 0
        else:
            return raw, 0

EVAL_MODEL = CleanOllamaModel(model="gemma4:31b-cloud")

