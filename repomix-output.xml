  const activeChat = chats.find(c => c.id === activeChatId) || null;
  const messages = activeChat?.messages || [];

  useEffect(() => {
    localStorage.setItem('session_id', sessionId);
  }, [sessionId]);

  // Смена фраз лоадера + очистка
